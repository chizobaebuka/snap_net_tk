NODE_ENV= // development | test | production (defaults to development)

DB_HOST= // your_database_host e.g, localhost
DB_PORT= // your_database_port e.g, 3307
DB_USERNAME= // your_database_username e.g, user
DB_PASSWORD= // your_database_password
DB_DATABASE= // your_database_name e.g, workforce_db
DB_POOL_SIZE= // max MySQL connections per instance (defaults to 10) - tune down as you add replicas so total connections stay under the DB's max_connections

RABBITMQ_URI= // your_rabbitmq_uri e.g amqp://user:password@localhost:5672
RABBITMQ_PREFETCH_COUNT= // max unacked messages per consumer instance (defaults to 10) - controls how evenly work spreads across worker replicas

REDIS_URI= // your_redis_uri e.g redis://localhost:6379
# For Upstash, the URI will be different, e.g., rediss://default:password@endpoint:port

PORT= // your_port (defaults to 3000)

JWT_SECRET= // your_secret_key (min 16 characters, required)

CORS_ORIGIN= // allowed origin for browser clients, e.g. https://app.example.com (defaults to * - lock this down in production)

# All of the above (except NODE_ENV/PORT/CORS_ORIGIN, which have defaults) are
# validated on boot - the app refuses to start if any required var is missing.
